[
  {
    "name": "theme_info",
    "theme_name": "feedback",
    "theme_label": "t:theme_label",
    "theme_description": "t:theme_description",
    "theme_version": "2.0.0",
    "theme_scope": "community",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://github.com/baklib-templates/feedback",
    "theme_support_url": "https://github.com/baklib-templates/feedback",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/${lang}/cover.png",
      "images/theme/${lang}/index.png",
      "images/theme/${lang}/roadmap.png",
      "images/theme/${lang}/page.png"
    ],
    "theme_languages": [
      {
        "name": "简体中文",
        "value": "zh-CN"
      },
      {
        "name": "English",
        "value": "en"
      }
    ],
    "recommendations": {
      "color_schemas": {
        "baklib": {
          "name": "t:schema.recommendations.baklib.name",
          "colors": {
            "--theme-color-primary": "#0F766E",
            "--theme-color-secondary": "#C2410C",
            "--theme-color-accent": "#0F172A",
            "--theme-color-info": "#60A5FA",
            "--theme-color-success": "#14B8A6",
            "--theme-color-warning": "#FDBA74"
          }
        },
        "fashion": {
          "name": "t:schema.recommendations.fashion.name",
          "colors": {
            "--theme-color-primary": "#3D50E0",
            "--theme-color-secondary": "#E91E63",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#2196F3",
            "--theme-color-success": "#4CAF50",
            "--theme-color-warning": "#FFC107"
          }
        },
        "old_school": {
          "name": "t:schema.recommendations.old_school.name",
          "colors": {
            "--theme-color-primary": "#9C27B0",
            "--theme-color-secondary": "#673AB7",
            "--theme-color-accent": "#AAAAAA",
            "--theme-color-info": "#418CC8",
            "--theme-color-success": "#29B52F",
            "--theme-color-warning": "#FFC107"
          }
        }
      }
    }
  },
  {
    "name": "t:settings_schema.generic.name",
    "settings": [
      {
        "id": "logo_url",
        "type": "image_picker",
        "ratio": "3:1",
        "width": 150,
        "label": "t:settings_schema.generic.settings.logo_url.label",
        "info": "t:settings_schema.generic.settings.logo_url.info"
      },
      {
        "id": "is_allow_published",
        "type": "checkbox",
        "label": "t:settings_schema.generic.settings.is_allow_published.label",
        "info": "t:settings_schema.generic.settings.is_allow_published.info",
        "default": false
      },
      {
        "id": "feedback_useful_type",
        "type": "text",
        "label": "t:settings_schema.generic.settings.feedback_useful_type.label",
        "placeholder": "t:settings_schema.generic.settings.feedback_useful_type.placeholder",
        "default": "😊"
      },
      {
        "id": "copyright_info",
        "type": "text",
        "label": "t:settings_schema.generic.settings.copyright_info.label",
        "placeholder": "t:settings_schema.generic.settings.copyright_info.placeholder"
      },
      {
        "id": "changelog_path",
        "type": "text",
        "label": "t:settings_schema.generic.settings.changelog_path.label"
      }
    ]
  },
  {
    "name": "t:settings_schema.generic.header_name",
    "settings": [
      {
        "id": "header_menu_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.header_menu_html.label",
        "info": "t:settings_schema.generic.settings.header_menu_html.info",
        "rows": 10,
        "default": "<a class='underline text-base-content/60 hover:no-underline' href='#0'>About</a>",
        "placeholder": "<a class='underline text-base-content/60 hover:no-underline' href='#0'>About</a>"
      },
      {
        "id": "footer_menu_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.footer_menu_html.label",
        "info": "t:settings_schema.generic.settings.footer_menu_html.info",
        "rows": 10,
        "default": "<li><a class='underline text-base-content/60 hover:no-underline' href='#0'>About</a></li>",
        "placeholder": "<li><a class='underline text-base-content/60 hover:no-underline' href='#0'>About</a></li>"
      }
    ]
  },
  {
    "name": "t:settings_schema.generic.head_title",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "t:settings_schema.generic.settings.head_html.label",
        "info": "t:settings_schema.generic.settings.head_html.info",
        "rows": 10,
        "placeholder": "t:settings_schema.generic.settings.head_html.placeholder"
      }
    ]
  },

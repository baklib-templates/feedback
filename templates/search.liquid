<div class="overflow-visible h-auto pb-12 min-h-screen bg-base-200">
  <div class="max-w-7xl mx-auto relative pt-24 px-4 sm:px-6">
    <div class="rounded-t-2xl border border-b-0 border-primary/20 bg-primary/10 p-5 text-base-content">
      <div class="relative flex items-center mb-3 text-center">
        <a class="absolute flex text-sm font-semibold leading-6 text-primary hover:text-primary/80" href="{{ site.index_path }}">
          <svg viewBox="0 -9 3 24" class="w-auto h-6 mr-3 overflow-visible">
            <path d="M3 0L0 3L3 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>{{ "generic.back" | t }}</span>
        </a>
        <h1 class="flex justify-center flex-grow w-0 text-lg">{{ "generic.search" | t }}</h1>
      </div>
      {% form_tag 'search' %}
        <div class="relative flex items-center">
          <input type="text" name="{{form.keywords_field_name}}" value="{{ search.keywords | escape_once }}" class="block w-full rounded-xl border-0 bg-base-100 py-3 pl-2 pr-8 text-sm text-base-content outline-none placeholder:text-base-content/60" placeholder="{{ "placeholders.search" | t }}">
        </div>
      {% endform_tag %}

      {% if search.tag or search.keywords %}
        <p class="mt-3 text-xs">
          {{ "generic.search" | t }}
          {% if search.tag %}
            <i class="px-2 py-1 rounded" style="background-color: {{ search.tag.color }}">{{ search.tag.name }}</i>
          {% endif %}
          {% if search.keywords %}
            <i>{{ search.keywords }}</i>
          {% endif %}
        </p>
      {% endif %}
    </div>

    {% if search.keywords or search.tag %}
      <ul class="list-none space-y-3 overflow-hidden rounded-b-2xl border border-t-0 border-base-300 bg-base-100 p-2">
        {% paginate_tag search.extends, as: 'extends' %}
          {% for extend in extends %}
            <li class="p-2"><a href="{{extend.url}}" class="text-primary hover:underline">{{extend.link_text}}</a></li>
          {% endfor %}
        {% endpaginate_tag %}

        {% paginate_tag search.pages, as: 'items' %}
          {% for page in items %}
            <li class="group flex items-center space-x-2 rounded-xl border border-base-300 px-2 py-2 hover:bg-primary/10">
              <div class="flex-grow w-0">
                <h3 class="flex gap-2 items-center h4 truncate text-base-content">
                  {% if page.template_name == 'page' %}
                    {% render 'page_icon', page: page, class: 'w-4 h-4 shrink-0 text-primary/70' %}
                  {% endif %}
                  <a href="{{ page.url }}" class="inline-block min-w-0 search-highlight-block">
                    {{ page.highlighted_search_title }}
                  </a>
                </h3>
                <p class="text-base-content/60 line-clamp-3 search-highlight-block">
                  {{ page.highlighted_search_content }}
                </p>
              </div>
              <span class="flex-shrink-0 inline-block w-0 h-0 border-[5px] border-l-primary border-t-transparent border-r-transparent border-b-transparent"></span>
            </li>
          {% else %}
            {{ "generic.empty" | t }}
          {% endfor %}
          {% render 'paginate', paginate: paginate %}
        {% endpaginate_tag %}
      </ul>
    {% else %}
      <div class="w-full mx-auto my-8 text-base-content/70">{{ "generic.empty" | t }}</div>
    {% endif %}
  </div>
</div>

{% layout none %}

<div id="toast-interactive" class="fixed top-10 left-1/2 z-50 p-4 w-full max-w-xs text-base-content/70 bg-base-100 rounded-lg shadow border border-base-300 transform -translate-x-1/2" role="alert" x-data="{ open: true }" x-show="open" x-init="setTimeout(() => { open = false }, 5000)" >
    <div class="flex">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-8 h-8 rounded-lg text-primary bg-primary/10">
          <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
          <span class="sr-only">Success icon</span>
        </div>
        <div class="ml-3 text-sm font-normal text-base-content">
          {{ 'toast.reply_published' | t }}
        </div>
        <button type="button" class="inline-flex p-1.5 -mx-1.5 -my-1.5 ml-auto w-8 h-8 text-base-content/60 bg-base-100 rounded-lg hover:text-base-content focus:ring-2 focus:ring-base-300 hover:bg-base-200" data-dismiss-target="#toast-interactive" aria-label="Close" @click="open=false">
            <span class="sr-only">Close</span>
            <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
        </button>
    </div>
</div>

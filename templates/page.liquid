{% assign pages = page.parent.children %}
{% search pages, keywords: page.settings.title, by_user: false %}
    {%  assign pages = search.pages %}
{% endsearch %}
{% query related_pages from pages %}
{
"where": {
"template_name_eq": "page",
"full_path_not_eq": "{{ page.path }}"
},
"limit": 2
}
{% endquery %}
{% assign avatar_url = 'https://api.dicebear.com/7.x/rings/svg?seed=' | append: page.author.id %}
{% assign page_icon_value = page.settings.icon.value | default: page.settings.icon | default: 'message-square' %}
{% assign page_status = page.settings.status.value | default: page.settings.status | default: 'inbox' %}
{% assign page_board = page.settings.board.value | default: page.settings.board | default: 'feature_request' %}
{% case page_status %}
{% when 'inbox' %}{% assign status_display = 'roadmap.status.inbox' | t %}
{% when 'planned' %}{% assign status_display = 'roadmap.status.planned' | t %}
{% when 'in_progress' %}{% assign status_display = 'roadmap.status.in_progress' | t %}
{% when 'completed' %}{% assign status_display = 'roadmap.status.completed' | t %}
{% else %}
  {% if page_status contains 't:' %}
    {% assign status_display = page_status | replace: 't:', '' | t %}
  {% else %}
    {% assign status_display = page_status %}
  {% endif %}
{% endcase %}
{% if page_board contains 't:' %}
  {% assign board_display = page_board | replace: 't:', '' | t %}
{% else %}
{% case page_board %}
{% when 'feature_request' %}{% assign board_display = 'roadmap.board.feature_request' | t %}
{% when 'bug' %}{% assign board_display = 'roadmap.board.bug' | t %}
{% when 'task' %}{% assign board_display = 'roadmap.board.task' | t %}
{% when 'question' %}{% assign board_display = 'roadmap.board.question' | t %}
{% else %}{% assign board_display = page_board %}
{% endcase %}
{% endif %}

<div class="relative z-50 mx-auto max-w-7xl px-4 sm:px-6 opacity-100 transition-transform ease-in-out transform scale-100 sm:my-10 sm:rounded-2xl">
  <div class="mb-10 sm:hidden">
    <button class="fixed left-4 top-4 rounded-xl border border-base-300 bg-base-200 p-1.5 text-[11px] uppercase tracking-wide">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <div class="mx-auto min-w-0">
    <div class="relative">
      <div class="h-full rounded-2xl border border-base-300 bg-base-100" id="dialog_content">
        <div class="flex flex-col h-full md:flex-row">
          <div class="w-full p-[18px] md:py-5 md:w-8/12 relative overflow-hidden">
            {% if page.published_at == nil %}
              <div class="mb-5 flex w-full items-center rounded-xl border border-accent/20 bg-accent/10 p-3">
                <div class="flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"
                    fill="currentColor" aria-hidden="true" class="w-4 h-4 text-accent">
                    <path fill-rule="evenodd"
                      d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"></path>
                  </svg></div>
                <p class="text-[13px] items-center ml-2 font-medium leading-5 text-base-content">{{ 'generic.under_review' | t }}</p>
              </div>
            {% endif %}

            <div class="w-full">
              <h1 class="flex gap-2 items-start pb-3 w-full text-lg font-semibold text-base-content content line-clamp-5">
                {% render 'page_icon', page: page, class: 'w-5 h-5 shrink-0 mt-0.5 text-primary/70' %}
                <span class="min-w-0">{{ page.settings.title }}</span>
              </h1>
              <div class="text-[15px] content text-base-content/70 max-h-[602px] h-full overflow-auto flow-root pt-1 ProseMirror prose sm:prose-base lg:prose-lg focus:outline-none">
                {{ page.settings.content }}
              </div>
            </div>

            <div class="pt-4 sm:pt-8"></div>
            <div class="mt-3">
              <div class="relative z-50 rounded-xl border border-base-300 bg-base-100">
                <button class="flex w-full cursor-pointer items-center justify-between rounded-xl p-2 px-3 shadow-sm main-transition hover:bg-base-200">
                  <p class="flex items-center text-sm font-medium text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mr-1.5 h-6 secondary-svg">
                      <path fill-rule="evenodd"
                        d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z"
                        clip-rule="evenodd"></path>
                    </svg>{{ 'generic.similar' | t }}
                  </p>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="secondary-svg w-3.5 h-3.5">
                    <path fill-rule="evenodd"
                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                      clip-rule="evenodd"></path>
                  </svg>
                </button>
              </div>

              <div class="-mt-1 rounded-b-2xl border border-t-0 border-base-300 pt-0.5">
                {% for similar_page in related_pages %}
                <div class="group mx-1.5 mt-2.5 flex items-center rounded-xl px-0.5 py-0.5 text-sm">
                  <a href="{{ similar_page.path }}"
                    data-turbo-frame="_top"
                    class="main-transition mr-2 flex w-full items-start gap-1 rounded-xl px-2.5 py-2 font-medium text-base-content/70 hover:bg-base-200">
                      <div class="flex-shrink-0 mr-2 mt-0.5">
                        {% render 'page_icon', page: similar_page, class: 'w-4 h-4 text-primary/70' %}
                      </div>
                    <div>
                      <div class="flex gap-1.5 items-center w-full cursor-pointer"><span class="font-medium text-left line-clamp-1">{{ similar_page.settings.title }}</span></div>
                      <div class="mt-0.5 text-xs text-left opacity-80 line-clamp-2">{{ similar_page.settings.content | strip_html | truncate: 280 }}</div>
                    </div>
                  </a>
                </div>
                {% endfor %}
              </div>
            </div>

            {% render 'reply_page_form', target: page %}
            <div class="mt-6 mb-8">
              <div class="flex justify-between items-center">
                <div class="flex gap-3 items-center pb-2 text-sm">
                  <button class="flex items-center px-2 pb-1.5 font-medium text-base-content border-b-2 border-primary cursor-pointer focus:ring-0 main-transition">
                    {{ 'buttons.comment' | t }}
                    <div class="inline-block px-1.5 py-px ml-2 text-xs font-medium text-base-content rounded-full bg-base-200">
                      {{ page.comments | size }}
                    </div>
                  </button>
                </div>
                <button type="button" class="text-xs text-base-content/60 hover:text-base-content">{{ 'generic.by_popularity' | t }}</button>
              </div>

              {% assign answers = page.comments | roots | order_by: '-feedbacks_count' %}
              <div class="flow-root justify-center items-center">
                <ul role="list" class="pl-0 list-none">
                  <div class="overflow-y-auto pb-8 custom-scrollbar-stronger">
                    <div class="pt-2 opacity-100" id="page_{{ page.id }}_replies_list">
                      {% for answer in answers %}
                      {% render 'reply', reply: answer %}
                      {% endfor %}
                    </div>
                  </div>
                </ul>
              </div>
            </div>
          </div>
          <div class="hidden relative pb-2 w-full text-sm text-base-content/70 rounded-tr-lg md:block border-base-300 md:border-l md:w-4/12">
            <div class="relative rounded-tr-md">
              <div class="absolute active:scale-[100%] hidden md:flex hover:scale-110 scale-100 transform-gpu -z-10 top-0 h-[50px] lg:h-[58.84px] divide-base-300 divide-y w-7 lg:w-8 items-center justify-start flex-col -right-[31.5px] lg:-right-[41px] bg-base-200/50 border shadow-sm border-base-300 hover:border-base-300 rounded-xl">
                {% if page.prev_page %}
                <a tabindex="-1"
                  href="{{ page.prev_page.path }}"
                  data-turbo-frame="_top"
                  class="flex justify-center items-center p-1 w-full h-full rounded-none rounded-t-md border-0 hover:bg-base-200 bg-base-100"
                  aria-label="{{ 'paginate.previous' | t }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="secondary-svg !w-3.5 !h-3.5">
                    <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
                  </svg>
                </a>
                {% else %}
                <span tabindex="-1" class="flex justify-center items-center p-1 w-full h-full rounded-none rounded-t-md border-0 bg-base-100/40 opacity-40 cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="secondary-svg !w-3.5 !h-3.5">
                    <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
                  </svg>
                </span>
                {% endif %}
                {% if page.next_page %}
                <a tabindex="-1"
                  href="{{ page.next_page.path }}"
                  data-turbo-frame="_top"
                  class="p-1 w-full flex bg-base-100/40 hover:bg-base-100 rounded-none rounded-b-md items-center justify-center border-0 h-full"
                  aria-label="{{ 'paginate.next' | t }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="secondary-svg !w-3.5 !h-3.5">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                </a>
                {% else %}
                <span tabindex="-1" class="p-1 w-full flex bg-base-100/40 rounded-none rounded-b-md items-center justify-center border-0 h-full opacity-40 cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="secondary-svg !w-3.5 !h-3.5">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                </span>
                {% endif %}
              </div>
              <div class="grid grid-cols-5 gap-y-4 items-center p-4 border-b border-base-300" x-data="{ status: '{{ page_status }}', board: '{{ page_board }}', board_name: {{ board_display | json }}, status_name: {{ status_display | json }}, icon: '{{ page_icon_value }}' }">
                <div class="col-span-2"><span class="font-medium text-base-content">{{ 'generic.votes' | t }}</span></div>
                <div class="col-span-3">
                  <div class="flex items-center"
                    x-data="{ posted_feedback: {{ page.visitor_posted_feedback | present? }}, feedback_count: {{ page | feedback_type_count: site.settings.feedback_useful_type }}  } ">
                    <div x-show="posted_feedback == true" @click="posted_feedback=false;feedback_count--" x-cloak>
                      {% form_tag 'delete_feedback', page: page, useful_type: site.settings.feedback_useful_type %}
                      <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type  }}"
                        class="flex justify-center items-center px-2 py-1 w-16 text-base-content/60 rounded-xl border shadow-none bg-base-200/50 border-base-300 hover:bg-base-200">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                          class="flex-shrink-0 mr-2 w-5 h-5 text-base-content/60"
                          :class="{ '!text-primary': 'posted_feedback' }">
                          <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
                        </svg>
                        <p class="font-medium" x-text="feedback_count"></p>
                      </button>
                      {% endform_tag %}
                    </div>
                    <div x-show="posted_feedback == false" @click="posted_feedback=true;feedback_count++" x-cloak>
                      {% form_tag 'feedback', page: page %}
                      <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
                        class="flex justify-center items-center px-2 py-1 w-16 text-base-content/60 rounded-xl border shadow-none bg-base-200/50 border-base-300 hover:bg-base-200">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                          class="flex-shrink-0 mr-2 w-5 h-5 text-base-content/60">
                          <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd"></path>
                        </svg>
                        <p class="font-medium" x-text="feedback_count"></p>
                      </button>
                      {% endform_tag %}
                    </div>
                  </div>
                </div>

                {% if page.author.id == current_user.member_hashid %}
                  {% render 'edit_form', page: page, page_icon_value: page_icon_value, page_status: page_status, page_board: page_board, status_display: status_display, board_display: board_display %}
                {% else %}
                <div class="col-span-2"><span class="font-medium text-base-content">{{ 'schema.lucide_icons.name' | t }}</span></div>
                <div class="col-span-3">
                  <div class="inline-flex items-center px-2 py-1 rounded-xl border border-base-300 bg-base-200/50">
                    {% render 'page_icon', page: page, class: 'w-4 h-4 text-primary/70' %}
                  </div>
                </div>
                <div class="col-span-2"><span class="font-medium text-base-content">{{ 'generic.status_label' | t }}</span></div>
                <div class="overflow-hidden col-span-3 p-1.5 -m-1.5">
                  <div class="flex items-center">
                    {% render 'status_badge', status: page_status %}
                  </div>
                </div>
                <div class="col-span-2"><span class="font-medium text-base-content">{{ 'form.board_label' | t }}</span></div>
                <div class="col-span-3">
                  <div class="inline-flex w-full">
                    <div class="flex items-center px-2 py-1 text-xs font-medium truncate rounded-xl border text-base-content/70 border-base-300 bg-base-200/50">
                      <p class="truncate">{{ board_display }}</p>
                    </div>
                  </div>
                </div>
                {% endif %}
              </div>
            </div>
            <div class="grid grid-cols-5 gap-y-4 items-center p-4">
              <div class="col-span-2"><span class="font-medium text-base-content">{{ 'generic.time' | t }}</span></div>
              <div class="col-span-3">
                <p class="inline-block w-full min-w-0 font-medium first-letter:uppercase text-base-content">{{ page.created_at | time_ago }}</p>
              </div>
              <div class="col-span-2"><span class="font-medium text-base-content">{{ 'generic.author' | t }}</span></div>
              <div class="flex col-span-3 items-center">
                <div class="relative rounded-full">
                  <div class="flex overflow-hidden relative flex-shrink-0 justify-center items-center w-7 h-7 rounded-full">
                    <div class="absolute inset-0 bg-base-200/30"></div>
                    <img class="object-cover z-10 w-full h-full rounded-full" src="{{ page.author.avatar_url |  default: avatar_url }}">
                  </div>
                </div>
                <p class="ml-2 font-medium truncate text-base-content">{{ page.author.name }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
"name": "Post page",
"description": "Published page detail template",
"thumb_url": "images/theme/${lang}/page.png",
"sub_page_templates": ["page"],
"settings": [
{
"id": "icon",
"type": "select",
"label": "t:schema.lucide_icons.name",
"default": "message-square",
"choices_from": "$site.lucide_icons"
},
{
"id": "title",
"type": "text",
"placeholder": "",
"label": "t:form.title_label",
"info": "Title shown above the post body"
},
{
"id": "content",
"type": "richtext",
"label": "t:generic.content"
},
{
"id": "tags",
"type": "tag_picker",
"multiple": true,
"label": "t:generic.tags"
},
{
"id": "pinned",
"type": "checkbox",
"label": "t:schema.templates.page.settings.pinned.label",
"info": "t:schema.templates.page.settings.pinned.info",
"queryable": true,
"default": false
},
{
"id": "status",
"type": "select",
"label": "t:generic.status_label",
"queryable": true,
"choices": [
{ "label": "t:roadmap.status.inbox", "value": "inbox" },
{ "label": "t:roadmap.status.planned", "value": "planned" },
{ "label": "t:roadmap.status.in_progress", "value": "in_progress" },
{ "label": "t:roadmap.status.completed", "value": "completed" }
]},
{
"id": "board",
"type": "select",
"label": "t:form.board_label",
"queryable": true,
"choices": [
{ "label": "t:roadmap.board.feature_request", "value": "feature_request" },
{ "label": "t:roadmap.board.bug", "value": "bug" },
{ "label": "t:roadmap.board.task", "value": "task" },
{ "label": "t:roadmap.board.question", "value": "question" }
]
}
],
"user_creatable": true,
"user_editable": true,
"user_deletable": true,
"user_permitted_attributes": ["icon", "title", "content", "status", "board", "pinned"]
}
{% endschema %}

{% assign pages = site.pages['/'].children_in_list  %}

<div class="min-h-screen bg-base-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-8 lg:py-10">
    {% render 'section_hero', description: page.settings.description %}

    <div class="flex flex-col gap-8 lg:flex-row lg:items-start">
      <div class="min-w-0 flex-1 lg:w-3/4">
        <turbo-frame id="feedback-list" class="block">
          {% assign order_by = params.sort  %}
          {% if order_by %}
            {% assign pages = pages | order_by: order_by %}
          {% endif %}
          {% query has_pinned from pages %}
            {
              "where": {
                "settings.templates/page.liquid:pinned_eq": "true"
              }
            }
          {% endquery %}
          {% assign has_pinned = has_pinned | size %}
          {% assign q_present = params.q | present?  %}
          {% if q_present %}
            {% search pages, keywords: params.q %}
                {% assign pages = search.pages %}
            {% endsearch %}
          {% endif %}
          {% assign query_pages =  pages %}
          {% if has_pinned > 0 %}
            {% query pages from pages %}
            {
              "where": {
                "settings.templates/page.liquid:status_eq": "{{ params.status }}",
                "settings.templates/page.liquid:board_eq": "{{ params.board }}",
                "settings.templates/page.liquid:pinned_eq": "false"
              }
            }
            {% endquery %}
          {% else %}
            {% query pages from pages %}
            {
              "where": {
                "settings.templates/page.liquid:status_eq": "{{ params.status }}",
                "settings.templates/page.liquid:board_eq": "{{ params.board }}"
              }
            }
            {% endquery %}
          {% endif %}

          {% render 'filter' %}

          <div class="flex flex-col gap-3 mt-2">
            {% if (params._page == '1' or params._page == nil) and has_pinned > 0  %}
              {% query pinned_pages from query_pages %}
              {
                "where": {
                  "settings.templates/page.liquid:status_eq": "{{ params.status }}",
                  "settings.templates/page.liquid:board_eq": "{{ params.board }}",
                  "settings.templates/page.liquid:pinned_eq": "true"
                }
              }
              {% endquery %}
              {% for page in pinned_pages %}
                {% render 'page', page: page %}
              {% endfor %}
            {% endif %}
            {% paginate_tag pages, per: 12 %}
              {% for page in pages %}
                {% render 'page', page: page %}
              {% endfor %}
            {% endpaginate_tag %}
          </div>
          {% render 'paginate', paginate: paginate %}
        </turbo-frame>
      </div>

      <aside class="w-full shrink-0 space-y-4 lg:w-1/4 lg:max-w-xs">
        {% if current_user %}
          {% assign my_posts = current_user.pages | order_by: '-published_at' %}
          {% assign my_posts_total = current_user.pages_count | default: 0 %}
          <section class="rounded-2xl border border-base-300 bg-primary/10 p-4">
            <h2 class="mb-3 text-sm font-semibold text-base-content">
              {{ 'home.your_posts' | t }}
              {% if my_posts_total > 0 %}
                <span class="font-normal text-base-content/50">({{ my_posts_total }})</span>
              {% endif %}
            </h2>
            {% if my_posts.size > 0 %}
              <ul class="space-y-2">
                {% for post in my_posts %}
                  {% if forloop.index <= 3 %}
                    {% assign post_status = post.settings.status | default: 'inbox' %}
                    {% case post_status %}
                    {% when 'planned' %}{% assign status_dot_class = 'bg-info' %}
                    {% when 'in_progress' %}{% assign status_dot_class = 'bg-warning' %}
                    {% when 'completed' %}{% assign status_dot_class = 'bg-success' %}
                    {% else %}{% assign status_dot_class = 'bg-neutral' %}
                    {% endcase %}
                    <li>
                      <a
                        href="{{ post.path }}"
                        class="flex gap-2.5 items-start rounded-xl py-1.5 text-sm transition-colors hover:bg-base-200/80"
                      >
                        <span class="mt-1.5 w-2 h-2 shrink-0 rounded-full {{ status_dot_class }}" aria-hidden="true"></span>
                        <span class="font-medium leading-snug text-base-content line-clamp-2">{{ post.settings.title }}</span>
                      </a>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
              <a href="/s/profile?type=post" class="inline-block mt-3 text-sm font-medium text-primary hover:underline">
                {{ 'home.view_all_activity' | t }}
              </a>
            {% else %}
              <p class="text-sm text-base-content/60">{{ 'home.no_posts_yet' | t }}</p>
            {% endif %}
          </section>
        {% endif %}

        {% capture board_query_suffix %}status={{ params.status }}&sort={{ params.sort }}&q={{ params.q }}{% endcapture %}
        <section class="rounded-2xl border border-base-300 bg-base-100 p-4">
          <h2 class="mb-3 text-sm font-semibold text-base-content">{{ 'home.boards' | t }}</h2>
          <ul class="space-y-1">
            <li>
              <a href="?board=&{{ board_query_suffix }}" class="flex gap-2.5 items-center rounded-xl px-2 py-2 text-sm text-base-content/80 hover:bg-base-200/80 {% if params.board == blank %}bg-primary/10 font-medium text-primary{% endif %}">
                {% render 'icon', name: 'message-square', class: 'w-4 h-4 shrink-0 text-primary/70' %}
                {{ 'home.view_all_posts' | t }}
              </a>
            </li>
            <li>
              <a href="?board=feature_request&{{ board_query_suffix }}" class="flex gap-2.5 items-center rounded-xl px-2 py-2 text-sm text-base-content/80 hover:bg-base-200/80 {% if params.board == 'feature_request' %}bg-primary/10 font-medium text-primary{% endif %}">
                {% render 'icon', name: 'lightbulb', class: 'w-4 h-4 shrink-0 text-primary/70' %}
                {{ 'roadmap.board.feature_request' | t }}
              </a>
            </li>
            <li>
              <a href="?board=bug&{{ board_query_suffix }}" class="flex gap-2.5 items-center rounded-xl px-2 py-2 text-sm text-base-content/80 hover:bg-base-200/80 {% if params.board == 'bug' %}bg-primary/10 font-medium text-primary{% endif %}">
                {% render 'icon', name: 'bug', class: 'w-4 h-4 shrink-0 text-primary/70' %}
                {{ 'roadmap.board.bug' | t }}
              </a>
            </li>
            <li>
              <a href="?board=task&{{ board_query_suffix }}" class="flex gap-2.5 items-center rounded-xl px-2 py-2 text-sm text-base-content/80 hover:bg-base-200/80 {% if params.board == 'task' %}bg-primary/10 font-medium text-primary{% endif %}">
                {% render 'icon', name: 'list', class: 'w-4 h-4 shrink-0 text-primary/70' %}
                {{ 'roadmap.board.task' | t }}
              </a>
            </li>
            <li>
              <a href="?board=question&{{ board_query_suffix }}" class="flex gap-2.5 items-center rounded-xl px-2 py-2 text-sm text-base-content/80 hover:bg-base-200/80 {% if params.board == 'question' %}bg-primary/10 font-medium text-primary{% endif %}">
                {% render 'icon', name: 'help-circle', class: 'w-4 h-4 shrink-0 text-primary/70' %}
                {{ 'roadmap.board.question' | t }}
              </a>
            </li>
          </ul>
        </section>

        {% assign contributors = site.users | order_by: '-pages_count' %}
        <section class="rounded-2xl border border-base-300 bg-base-100 p-4">
          <h2 class="mb-3 text-sm font-semibold text-base-content">{{ 'home.most_helpful' | t }}</h2>
          <ul class="space-y-2.5">
            {% for user in contributors %}
              {% if forloop.index <= 8 %}
                {% assign rank = forloop.index %}
                {% assign contributor_avatar = 'https://api.dicebear.com/7.x/rings/svg?seed=' | append: user.id %}
                <li class="flex gap-2.5 items-center">
                  <span class="flex justify-center items-center w-5 shrink-0 text-xs font-bold tabular-nums {% if rank == 1 %}text-warning{% elsif rank == 2 %}text-base-content/50{% elsif rank == 3 %}text-warning/60{% else %}text-base-content/30{% endif %}">
                    {% if rank == 1 %}
                      {% render 'icon', name: 'star', class: 'w-4 h-4 fill-current' %}
                    {% elsif rank == 2 %}
                      {% render 'icon', name: 'star', class: 'w-4 h-4' %}
                    {% elsif rank == 3 %}
                      {% render 'icon', name: 'star', class: 'w-4 h-4 opacity-70' %}
                    {% else %}
                      {{ rank }}
                    {% endif %}
                  </span>
                  <img src="{{ user.avatar_url | default: contributor_avatar }}" alt="" class="object-cover w-7 h-7 rounded-full bg-base-200 shrink-0" width="28" height="28">
                  <span class="flex-1 min-w-0 text-sm font-medium truncate text-base-content">{{ user.name }}</span>
                  <span class="inline-flex gap-1 items-center text-sm font-semibold tabular-nums text-base-content/70">
                    {{ user.pages_count }}
                    {% render 'icon', name: 'circle-check', class: 'w-3.5 h-3.5 text-success' %}
                  </span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </section>
      </aside>
    </div>
  </div>
</div>

{% schema %}
{
"name": "Index",
"description": "Community Index Page Forum Theme",
"thumb_url": "images/theme/index.png",
"sub_page_templates": ["page", "roadmap"],
"settings": [
{
"id": "description",
"type": "code",
"label": "t:schema.templates.index.settings.description.label",
"default": "<div class=\"w-full max-w-4xl px-4 mx-auto text-sm leading-relaxed space-y-4\">\n  <p>\n    Welcome! We value your feedback. Before submitting, please note:\n  </p>\n  <ul class=\"space-y-2 list-disc list-inside\">\n  <li>\n  ✅ <strong>Search existing posts</strong> to avoid duplicates;\n  </li>\n    <li>\n      ✅ <strong>One issue or idea per post</strong> so we can respond faster;\n    </li>\n    <li>\n  📌 <strong>Feature requests, bugs, UX feedback, and questions</strong> are all welcome;\n    </li>\n  </ul>\n  <p>\n    🙏 Thank you for helping us improve the product.\n  </p>\n</div>"
}
]
}
{% endschema %}

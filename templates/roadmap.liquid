{% assign pages = page.children_in_list %}
{% assign arr = "inbox,planned,in_progress,completed" | split: "," %}
{% assign order_by = params.sort | default: '-created_at' %}
{% if order_by %}
{% assign pages = pages | order_by: order_by %}
{% endif %}

<div class="bg-base-200">

  {% search pages, keywords: params.q %}
    {% assign q_present = params.q | present? %}
    {% if q_present %}
    {% assign pages = search.pages %}
    {% endif %}
  {% endsearch %}

  <div class="px-4 pt-8 mx-auto max-w-7xl sm:px-6">
    <div class="flex flex-col gap-4 mb-6 rounded-2xl border border-primary/20 bg-primary/10 px-6 py-6 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-2xl font-bold tracking-tight text-base-content sm:text-3xl">{% if page.settings.title != blank %}{{ page.settings.title }}{% else %}{{ 'nav.roadmap' | t }}{% endif %}</h1>
      {% render 'roadmap/filter' %}
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 px-4 py-8 mx-auto max-w-7xl sm:px-6 md:grid-cols-2 lg:grid-cols-4">
    {% for status in arr %}
    {% assign pages1 = '' %}
    {% assign sts = params.status | blank? %}
    {% if sts or params.status == status %}
    {% query filter_query from pages %}
    {
    "where": {
    "settings.templates/page.liquid:status_eq": status,
    "settings.templates/page.liquid:board_eq": "{{ params.board }}"
    }
    }
    {% endquery %}
    {% assign pages1 = filter_query %}
    {% endif %}
    {% case status %}
    {% when 'inbox' %}{% assign col_lane_class = 'bg-neutral/10 border-neutral/20' %}{% assign col_label_class = 'text-base-content' %}
    {% when 'planned' %}{% assign col_lane_class = 'bg-info/10 border-info/20' %}{% assign col_label_class = 'text-info' %}
    {% when 'in_progress' %}{% assign col_lane_class = 'bg-warning/10 border-warning/20' %}{% assign col_label_class = 'text-warning' %}
    {% when 'completed' %}{% assign col_lane_class = 'bg-success/10 border-success/20' %}{% assign col_label_class = 'text-success' %}
    {% else %}{% assign col_lane_class = 'bg-primary/10 border-primary/20' %}{% assign col_label_class = 'text-primary' %}
    {% endcase %}
    <div class="flex min-w-0 flex-col rounded-2xl border border-base-300 pb-4 {{ col_lane_class }}">
      <div class="flex sticky top-0 justify-between items-center px-3 py-3 backdrop-filter">
        <p class="font-semibold pointer-events-none max-w-[265px] flex items-center rounded-xl border px-3 py-1.5 text-xs {{ col_lane_class }} {{ col_label_class }}">
          <span class="inline-flex items-center truncate first-letter:uppercase">
            {% case status %}
            {% when 'inbox' %}{{ 'roadmap.status.inbox' | t }}
            {% when 'planned' %}{{ 'roadmap.status.planned' | t }}
            {% when 'in_progress' %}{{ 'roadmap.status.in_progress' | t }}
            {% when 'completed' %}{{ 'roadmap.status.completed' | t }}
            {% else %}{{ status }}
          {% endcase %}</span>
        </p>
        <div class="flex gap-2 items-center mr-1"><code
            class="rounded-lg border border-base-300 bg-base-100 px-2 py-0.5 text-xs !font-semibold text-base-content/80">{{ pages1 | size }}</code>
        </div>
      </div>
      <div class="relative">
        <div class="">
          <div class="relative custom-scrollbar sm:overflow-y-auto sm:h-[60vh]">
            {% for page in pages1 %}
            {% render 'roadmap/card', page: page %}
            {% endfor %}
            <div class="mt-5 sm:mt-8">
              <div class="sm:hidden">
                <div class="px-1 -mt-3"><button class="btn btn-ghost btn-sm">{{ 'generic.more' | t }}</button>
                </div>
              </div>
              
            </div>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
"name": "Roadmap",
"description": "Roadmap list page",
"thumb_url": "images/theme/page.png",
"sub_page_templates": ["page"],
"settings": [
{
"id": "title",
"type": "text",
"placeholder": "",
"label": "t:schema.templates.roadmap.settings.title.label",
"info": "Page title shown in the roadmap header"
},
{
"id": "tags",
"type": "tag_picker",
"multiple": true,
"label": "t:generic.tags"
}
]
}
{% endschema %}

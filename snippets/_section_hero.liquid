{% comment %}
  Section hero with brand-tinted background (DaisyUI semantic colors).
  @param description {String} optional HTML
  @param class {String} optional extra wrapper classes
{% endcomment %}
{% if description != blank %}
<header class="mb-8 max-w-3xl rounded-2xl border border-primary/20 bg-primary/10 px-6 py-8">
    <div class="mt-3 text-sm leading-relaxed text-base-content/70 prose prose-sm max-w-none">
      {{ description }}
    </div>
</header>
{% endif %}
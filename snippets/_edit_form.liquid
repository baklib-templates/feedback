{% form_tag 'edit_page', page, class: 'contents' %}

<input value="{{ page_status | default: 'inbox' }}" autocomplete="off" type="hidden" name="page[template_variables][status]" x-model="status">
<input value="{{ page_board | default: 'feature_request' }}" autocomplete="off" type="hidden" name="page[template_variables][board]" x-model="board">
<input value="{{ page_icon_value | default: 'message-square' }}" autocomplete="off" type="hidden" name="page[template_variables][icon]" x-model="icon">
<input value="update_page_success" autocomplete="off" type="hidden" name="return_template_name">

<div class="col-span-2"><span class="font-medium">{{ 'schema.lucide_icons.name' | t }}</span></div>
<details class="dropdown dropdown-end col-span-3">
  <summary class="flex items-center px-2 py-1 text-xs font-medium truncate rounded-md border text-base-content/70 border-base-300 bg-base-200/50 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
    {% render 'icon', name: page_icon_value, class: 'w-4 h-4 text-primary/70' %}
  </summary>
  <ul class="dropdown-content menu z-[999] max-h-48 min-w-[10rem] overflow-y-auto rounded-box border border-base-300 bg-base-100 p-1 shadow-lg">
    {% assign lucide_icon_lines = site.settings.lucide_icons | newline_to_br | split: '<br />' %}
    {% for icon_line in lucide_icon_lines %}
      {% assign icon_name = icon_line | strip %}
      {% if icon_name != blank %}
      <li>
        <button type="submit"
          class="text-sm"
          @click="icon = '{{ icon_name }}'; $el.closest('details').removeAttribute('open')"
        >{{ icon_name }}</button>
      </li>
      {% endif %}
    {% endfor %}
  </ul>
</details>

<div class="col-span-2"><span class="font-medium">{{ 'generic.status_label' | t }}</span></div>
<details class="dropdown dropdown-end col-span-3">
  <summary class="px-2 py-1 text-xs font-medium rounded-md border border-base-300 bg-base-200/50 hover:bg-base-200 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
    {{ status_display }}
  </summary>
  <ul class="dropdown-content menu z-[999] min-w-[10rem] rounded-box border border-base-300 bg-base-100 p-1 shadow-lg">
    <li>
      <button type="submit"
        class="text-sm"
        @click="status = 'inbox'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.status.inbox' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="status = 'planned'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.status.planned' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="status = 'in_progress'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.status.in_progress' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="status = 'completed'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.status.completed' | t }}</button>
    </li>
  </ul>
</details>

<div class="col-span-2"><span class="font-medium">{{ 'form.board_label' | t }}</span></div>
<details class="dropdown dropdown-end col-span-3">
  <summary class="flex items-center px-2 py-1 text-xs font-medium truncate rounded-md border text-base-content/70 border-base-300 bg-base-200/50 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
    <span class="truncate">{{ board_display }}</span>
  </summary>
  <ul class="dropdown-content menu z-[999] min-w-[10rem] rounded-box border border-base-300 bg-base-100 p-1 shadow-lg">
    <li>
      <button type="submit"
        class="text-sm"
        @click="board = 'feature_request'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.board.feature_request' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="board = 'bug'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.board.bug' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="board = 'task'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.board.task' | t }}</button>
    </li>
    <li>
      <button type="submit"
        class="text-sm"
        @click="board = 'question'; $el.closest('details').removeAttribute('open')"
      >{{ 'roadmap.board.question' | t }}</button>
    </li>
  </ul>
</details>
{% endform_tag %}

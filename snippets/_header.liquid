{%  assign default-logo = 'images/logo.png' | asset_url  %}
{% assign logo_url = site.favicon_url | presence | default: site.settings.logo_url | presence | default: default-logo %}

{%  assign pages = site.pages %}
{% query roadmap_list from pages %}
{
  "where": {
    "template_name_eq": "roadmap",
    "limit": 1
  }
}
{% endquery %}
{% assign roadmap = roadmap_list | first  %}
{% assign avatar_url = 'https://api.dicebear.com/7.x/rings/svg?seed=' | append: current_user.member_hashid %}
<script>
function getLastVisitCookie(userId) {
  const key = `last_visit_comments_${userId}`;
  const cookies = document.cookie.split('; ')
    .map(cookie => cookie.split('='))
    .reduce((acc, [k, v]) => {
      acc[k] = v;
      return acc;
    }, {});

  return cookies[key] || null;
}

function updateNewReplyCount() {
  const currentPath = window.location.pathname;
  if (currentPath === "/s/profile") {
    const countElem = document.getElementById('new-reply-count');
    if (countElem) countElem.style.display = 'none';
    return;
  }

  const current_UserId = {{ current_user.id }};
  const lastVisit = getLastVisitCookie(current_UserId);
  if(lastVisit){
    fetch(`/s/new-comment-count?created_after=${encodeURIComponent(lastVisit)}`)
    .then(res => res.text())
    .then(text => {
      const json = JSON.parse(text);
      const count = json.count  || 0
      const indicator = document.getElementById('new-reply-indicator');
      const countElem = document.getElementById('new-reply-count');
      if(count > 0){
        if(indicator) indicator.classList.remove('hidden');
        if(countElem) {
          countElem.textContent = count > 99 ? '99+' : count;
          countElem.style.display = 'inline-block';
        }
      } else {
        if(indicator) indicator.classList.add('hidden');
        if(countElem) {
          countElem.textContent = '';
          countElem.style.display = 'none';
        }
      }
    });
  }else {
    const key_1 = `last_visit_comments_${current_UserId}`;
    const value_1 = new Date().toISOString() ;
    document.cookie = `${key_1}=${value_1}; path=/; max-age=${60 * 60 * 24 * 365 * 10}; SameSite=Lax`;
    document.getElementById('new-reply-count').classList.remove('px-2');
  }
}

updateNewReplyCount();
</script>

<header class="overflow-hidden border-b border-base-300 bg-primary/10 shadow-sm">
  <div class="w-full">
    <div class="flex justify-between items-center px-4 pt-6 mx-auto max-w-7xl sm:px-6">
      <div class="flex items-center space-x-3">
        <img
          src="{{ logo_url }}"
          alt="{{ site.name }}"
          class="h-10 w-10 rounded-xl"
        />
        <span class="text-2xl font-bold text-base-content">{{ site.name }}</span>
      </div>
      {% if current_user %}
        <div class="relative" data-controller="dropdown">
          <button
            type="button"
            data-action="dropdown#toggle click@window->dropdown#hide"
            class="flex items-center px-3 py-2 space-x-2 rounded-full transition hover:bg-base-200"
          >
            <img src="{{ current_user.image |  default: avatar_url }}" class="w-8 h-8 rounded-full" />
            <span id="new-reply-indicator" class="hidden absolute top-0 right-0 mt-0 mr-0 w-3 h-3 bg-error rounded-full"></span>
          </button>

          <div
            data-dropdown-target="menu"
            class="hidden absolute right-0 z-10 mt-2 w-56 bg-base-100 rounded-xl border border-base-300 shadow-xl transition origin-top-right"
            data-transition-enter-from="opacity-0 scale-95"
            data-transition-enter-to="opacity-100 scale-100"
            data-transition-leave-from="opacity-100 scale-100"
            data-transition-leave-to="opacity-0 scale-95"
          >
            <div class="p-4 border-b border-base-300">
              <div class="flex items-center space-x-3">
                <img src="{{ current_user.image |  default: avatar_url }}" class="w-8 h-8 rounded-full" />
                <div class="text-sm font-semibold text-base-content">{{ current_user.name }}</div>
              </div>
            </div>

            <div class="py-1 divide-y divide-base-300">
              <a href="/s/profile?type=comment" target="_blank"
                class="flex items-center px-4 py-2 text-sm text-base-content hover:bg-base-200"
              >
                <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5.121 17.804A9.003 9.003 0 1 1 12 21a8.978 8.978 0 0 1-6.879-3.196z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ 'profile.activity' | t }}
                <span id="new-reply-count" class="px-2 py-0.5 ml-1 text-xs font-semibold text-error-content bg-error rounded-full"></span>
              </a>

              <a href="{{ current_user.profile_url }}" target="_blank" class="flex items-center px-4 py-2 text-sm text-base-content hover:bg-base-200">
                <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 12c2.21 0 4-1.79 4-4S14.21 4 12 4s-4 1.79-4 4 1.79 4 4 4z"/>
                  <path d="M4 20c0-2.21 3.582-4 8-4s8 1.79 8 4v1H4v-1z"/>
                </svg>
                {{ 'generic.profile' | t }}
              </a>
                {% form_tag 'sign_out' %}
                  <button type="submit" class="flex items-center px-4 py-2 w-full text-sm text-left text-error hover:bg-error/10">
                    <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M17 16l4-4m0 0l-4-4m4 4H7"/>
                      <path d="M3 12h4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {{ 'buttons.logout' | t }}
                  </button>
                {% endform_tag %}

            </div>
          </div>
        </div>
      {% else %}
        {% form_tag 'sign_in_with_baklib' %}
          <input value="true" type="hidden" name="sign_up">
          <button
          class="rounded-full border border-base-300 bg-base-100 px-6 py-2 font-semibold text-base-content shadow-sm transition hover:bg-base-200">{{ 'buttons.login' | t }}</button>
        {% endform_tag %}
      {% endif %}
    </div>
    <div class="flex items-center px-4 mx-auto mt-2 space-x-2 max-w-7xl sm:px-6">
      <a
        href="/"
        class="-mb-px flex items-center rounded-t-2xl border-b-0 px-2 sm:px-5 py-2 font-semibold {% if page.path == '/' %} border border-primary/20 bg-primary/10 text-primary shadow-sm {% else %} text-base-content/60 hover:text-base-content {% endif %}"
      >
        {% render 'icon', name: 'message-square', class: 'mr-2 w-5 h-5' %}
        {{ 'nav.feedback' | t }}
      </a>
      <a
        href="{{ roadmap.path }}"
        class="flex items-center rounded-t-2xl border-b-0 px-2 sm:px-5 py-2 font-semibold transition {% if page.template_name == 'roadmap' %} border border-primary/20 bg-primary/10 text-primary shadow-sm {% else %} text-base-content/60 hover:text-base-content {% endif %}"
        data-nav-tree-target="item"
      >
        {% render 'icon', name: 'route', class: 'mr-2 w-5 h-5' %}
        {{ 'nav.roadmap' | t }}
      </a>
      {% if site.settings.changelog_path %}
      <a
        href="{{site.settings.changelog_path}}"
        class="flex items-center px-2 sm:px-5 py-2 font-semibold text-base-content/60 transition hover:text-base-content"
      >
        {% render 'icon', name: 'refresh-cw', class: 'mr-2 w-5 h-5' %}
        {{ 'nav.changelog' | t }}
      </a>
      {% endif %}
    </div>
  </div>
</header>

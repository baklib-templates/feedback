{% if current_user %}
  <div class="flex space-x-3" id="create_reply_{{ target.id }}_form">
    <div class="w-full">
      {% form_tag 'reply' %}
        <input value="{{ target.full_slug }}" autocomplete="off" type="hidden" name="target_full_path">
        <input value="create_reply_success" autocomplete="off" type="hidden" name="return_template_name">
        <input value="true" autocomplete="off" type="hidden" name="reply[published]">

        <div class="relative p-1 mt-4 text-sm rounded-xl border border-base-300 shadow-sm transition-all bg-base-200/40 focus-within:border-primary focus-within:bg-base-100 focus-within:shadow-md">
          <textarea
            class="px-4 py-3 w-full placeholder:text-base-content/60 text-base-content bg-transparent border-0 resize-none focus:outline-none"
            rows="4"
            placeholder="{{ 'placeholders.reply' | t }}"
            name="reply[body]"
            required
          ></textarea>

          <div class="absolute right-3 bottom-3">
            <button
              type="submit"
              class="btn btn-primary flex items-center px-4 py-2 text-sm font-medium rounded-lg shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              @click="open = false;name=content.substring(0, 50)"
            >
              <svg class="mr-1.5 w-5 h-5 -rotate-45" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"></path>
              </svg>
              {{ 'buttons.comment' | t }}
            </button>
          </div>
        </div>

        <div id="reply_page_error" class="text-xs text-error"></div>
      {% endform_tag %}
    </div>
  </div>
{% else %}
  <div class="mt-4 rounded-xl border border-primary/20 bg-primary/10 p-3">
    <div class="flex">
      <div class="flex-shrink-0"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"
          fill="currentColor" aria-hidden="true" class="w-5 h-5 text-primary">
          <path fill-rule="evenodd"
            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
            clip-rule="evenodd"></path>
        </svg></div>
      <div class="flex-1 ml-3 md:flex md:justify-between">
        <p class="text-sm leading-5 text-base-content">{{ 'generic.under_comment' | t }}</p>
        <div class="flex items-center mt-3 text-sm font-medium leading-5 md:mt-0 md:ml-6">
        {% form_tag 'sign_in_with_baklib' %}
          <input value="true" type="hidden" name="sign_up">
          <button
            class="text-xs text-primary transition duration-150 ease-in-out cursor-pointer whitespace-no-wrap hover:text-primary/80 main-transition unstyled-button">{{ 'buttons.login' | t }} →</button>
        {% endform_tag %}
      </div>
      </div>
    </div>
  </div>
{% endif %}

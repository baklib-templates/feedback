<div class="flex items-center space-x-3" x-data="{
      status: '{{ params.status }}',
      board: '{{ params.board }}',
      sort: '{{ params.sort }}',
      q: '{{ params.q }}',
      showInput: {{ params.q | present? }}
    }">
  <a :href="`?status=${status}&board=${board}&sort=${sort}&q=${q}`" x-ref="filterSubmit" class="hidden">
  </a>
  <div class="flex relative items-center">
    <button
      class="flex h-10 w-10 items-center justify-center rounded-xl border border-base-300 bg-base-100 text-base-content/60 transition hover:bg-base-200"
      @click="showInput = true; $nextTick(() => $refs.searchInput.focus())" x-show="!showInput">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    </button>

    <div x-show="showInput"
      class="flex w-full max-w-md items-center rounded-xl border border-base-300 bg-base-100 px-2 py-1 transition focus-within:border-primary"
      @click.away="showInput = false">
      <svg class="w-5 h-5 text-base-content/60 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input type="text" placeholder="{{ 'placeholders.search' | t }}"
        class="flex-1 bg-transparent border-0 focus:outline-none focus:ring-0 focus:border-0 text-base-content placeholder:text-base-content/60 text-base"
        x-ref="searchInput" x-model="q"
        @keyup.enter="$nextTick(() => {$refs.filterSubmit.click()}); showInput = false" />
      <button @click="showInput = false" class="ml-2 p-2 text-base-content/60 hover:text-base-content">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
          class="w-3.5 h-3.5 secondary-svg">
          <path fill-rule="evenodd"
            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
  <div x-data="{ open: false, activeTab: 'status' }" class="relative">
    <button @click="open = !open"
      class="flex items-center rounded-xl border border-base-300 bg-base-200 px-4 py-2 text-base font-semibold text-base-content/70 shadow-sm transition hover:bg-base-200">
      <svg class="w-5 h-5 text-base-content/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path
          d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L15 13.414V19a1 1 0 01-1.447.894l-4-2A1 1 0 019 17v-3.586L3.293 6.707A1 1 0 013 6V4z"
          stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="ml-2">{{ 'generic.filter' | t }}</span>
      <svg :class="{'rotate-180': open}" class="ml-2 w-4 h-4 transition-transform" fill="none" stroke="currentColor"
        stroke-width="2" viewBox="0 0 24 24">
        <path d="M19 9l-7 7-7-7" />
      </svg>
    </button>

    <div x-show="open" @click.away="open = false" x-transition
      class="absolute left-0 top-full z-50 mt-2 w-96 rounded-2xl border border-base-300 bg-base-100 p-6 shadow-lg"
      >
      <div class="flex flex-wrap gap-2 mb-4 font-semibold">
        <button class="rounded-xl px-2 py-1"
          :class="activeTab === 'status' ? 'border border-primary/20 bg-primary/10 text-primary' : 'text-base-content/60 hover:text-base-content'" @click="activeTab = 'status'">{{ 'generic.status' | t }}</button>
        <button class="rounded-xl px-2 py-1"
          :class="activeTab === 'board' ? 'border border-primary/20 bg-primary/10 text-primary' : 'text-base-content/60 hover:text-base-content'" @click="activeTab = 'board'">{{ 'generic.board' | t }}</button>
      </div>
      <div>
        <div x-show="activeTab === 'status'">
          <div class="grid grid-cols-3 gap-4">
            <div @click="status = ''; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="status === '' ? 'text-primary' : ''">{{ 'generic.all_statuses' | t }}</div>
            <div @click="status = 'inbox'; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="status === 'inbox' ? 'text-primary' : ''">{{ 'roadmap.status.inbox' | t }}</div>
            <div :class="status === 'planned' ? 'text-primary' : ''"
            class="cursor-pointer"
              @click="status = 'planned'; $nextTick(() => {$refs.filterSubmit.click()}); open = false">{{ 'roadmap.status.planned' | t }}</div>
            <div :class="status === 'in_progress' ? 'text-primary' : ''"
            class="cursor-pointer"
              @click="status = 'in_progress'; $nextTick(() => {$refs.filterSubmit.click()}); open = false">{{ 'roadmap.status.in_progress' | t }}</div>
            <div :class="status === 'completed' ? 'text-primary' : ''"
            class="cursor-pointer"
              @click="status = 'completed'; $nextTick(() => {$refs.filterSubmit.click()}); open = false">{{ 'roadmap.status.completed' | t }}</div>
          </div>
        </div>
        <div x-show="activeTab === 'board'">
          <div class="grid grid-cols-3 gap-4">
            <div @click="board = ''; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="board === '' ? 'text-primary' : ''">{{ 'generic.all_boards' | t }}</div>
            <div @click="board = 'feature_request'; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="board === 'feature_request' ? 'text-primary' : ''">{{ 'roadmap.board.feature_request' | t }}</div>
            <div @click="board = 'bug'; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="board === 'bug' ? 'text-primary' : ''">{{ 'roadmap.board.bug' | t }}</div>
            <div @click="board = 'task'; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="board === 'task' ? 'text-primary' : ''">{{ 'roadmap.board.task' | t }}</div>
            <div @click="board = 'question'; $nextTick(() => {$refs.filterSubmit.click()}); open = false"
              class="cursor-pointer"
              :class="board === 'question' ? 'text-primary' : ''">{{ 'roadmap.board.question' | t }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <button
    class="flex items-center rounded-xl border border-base-300 bg-base-200 px-4 py-2 text-base font-semibold text-base-content shadow-sm transition hover:bg-base-200"
    :class="sort === '-created_at' ? 'bg-base-100' : ''"
    @click="sort = '-created_at';  $nextTick(() => {$nextTick(() => {$refs.filterSubmit.click()})})">
    <svg class="w-5 h-5 mr-2 text-base-content/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" />
      <path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    {{ 'generic.newest' | t }}
  </button>
  <button
    class="flex items-center rounded-xl border border-base-300 bg-base-200 px-4 py-2 text-base font-semibold text-base-content shadow-sm transition hover:bg-base-200"
    :class="sort === '-feedbacks_count' ? 'bg-base-100' : ''"
    @click="sort = '-feedbacks_count'; $nextTick(() => {$nextTick(() => {$refs.filterSubmit.click()})})">
    <svg class="w-5 h-5 mr-2 text-base-content/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    {{ 'generic.vote' | t }}
  </button>
</div>

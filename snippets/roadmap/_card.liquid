{% assign page_board = page.settings.board.value | default: page.settings.board | default: 'feature_request' %}
{% if page_board contains 't:' %}
  {% assign board_display = page_board | replace: 't:', '' | t %}
{% else %}
  {% case page_board %}
  {% when 'feature_request' %}{% assign board_display = 'roadmap.board.feature_request' | t %}
  {% when 'bug' %}{% assign board_display = 'roadmap.board.bug' | t %}
  {% when 'task' %}{% assign board_display = 'roadmap.board.task' | t %}
  {% when 'question' %}{% assign board_display = 'roadmap.board.question' | t %}
  {% else %}{% assign board_display = page_board %}
  {% endcase %}
{% endif %}
<div
  class="relative p-3 mx-2 mb-3 min-w-0 rounded-xl border border-base-300 bg-base-100 shadow-sm group main-transition hover:border-primary/20 hover:bg-base-200">
  <div class="relative">
    <div class="flex gap-2 items-start">
      {% render 'page_icon', page: page, class: 'w-4 h-4 shrink-0 mt-0.5 text-primary/70' %}
      <div class="min-w-0 flex-1">
        <p class="overflow-hidden text-sm font-semibold text-base-content line-clamp-3 content group-hover:underline decoration-base-300">
          {{ page.settings.title }}
        </p>
      </div>
    </div>
    <div class="flex flex-wrap gap-y-1 gap-x-2 justify-between items-end mt-1 h-full">
      <div class="flex flex-wrap gap-2 mt-1">
        <div class="inline-block">
          <div
            class="flex items-center truncate rounded-lg border border-base-300 bg-base-200/50 px-2 py-1 text-xs font-medium text-base-content/70">
            <p class="truncate">{{ board_display }}</p>
          </div>
        </div>
        <div
          class="flex items-center rounded-lg border border-base-300/60 px-2 py-1 text-xs font-medium text-base-content/60">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
            class="mr-1 w-3.5 h-3.5 text-base-content/50">
            <path fill-rule="evenodd"
              d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z"
              clip-rule="evenodd"></path>
          </svg>{{ page.comments | size }}
        </div>
      </div>
      <div class="relative z-10 flex flex-col mt-1 ml-auto"
        x-data="{ posted_feedback: {{ page.visitor_posted_feedback | present? }}, feedback_count: {{ page | feedback_type_count: site.settings.feedback_useful_type }} }"
        @click.stop>
        <div x-show="posted_feedback == true" @click="posted_feedback=false;feedback_count--" x-cloak class="flex">
          {% form_tag 'delete_feedback', page: page, useful_type: site.settings.feedback_useful_type, class:
          'flex' %}
          <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type  }}"
            class="flex w-16 items-center justify-center rounded-xl border border-base-300 bg-base-200/50 px-2 py-1 text-base-content/60 shadow-none hover:bg-base-200">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
              class="flex-shrink-0 mr-2 w-5 h-5 text-base-content/60"
              :class="{ '!text-primary': 'posted_feedback' }">
              <path fill-rule="evenodd"
                d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z"
                clip-rule="evenodd">
              </path>
            </svg>
            <p class="font-medium" x-text="feedback_count"></p>
          </button>
          {% endform_tag %}
        </div>

        <div x-show="posted_feedback == false" @click="posted_feedback=true;feedback_count++" class="flex" x-cloak>
          {% form_tag 'feedback', page: page, class: 'flex' %}
          <button name="feedback[useful_type]" value="{{ site.settings.feedback_useful_type }}"
            class="flex w-16 items-center justify-center rounded-xl border border-base-300 bg-base-200/50 px-2 py-1 text-base-content/60 shadow-none hover:bg-base-200">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
              class="flex-shrink-0 mr-2 w-5 h-5 text-base-content/60">
              <path fill-rule="evenodd"
                d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z"
                clip-rule="evenodd"></path>
            </svg>
            <p class="font-medium" x-text="feedback_count"></p>
          </button>
          {% endform_tag %}
        </div>
      </div>
    </div>

    <a
      class="absolute inset-0 rounded-xl"
      href="{{ page.path }}"
      data-turbo-frame="_top"
      aria-label="{{ page.settings.title }}"
    ></a>
  </div>
</div>

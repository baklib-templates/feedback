{% comment %}
  Status pill for feedback cards and sidebar.
  @param status {String} inbox | planned | in_progress | completed (or select label t:roadmap.status.*)
  @param class {String} optional extra classes
{% endcomment %}
{% assign raw_status = status.value | default: status | default: "inbox" %}
{% if raw_status contains "t:" %}
  {% assign status_key = raw_status | replace: "t:", "" %}
  {% assign page_status = status_key | split: "." | last %}
{% else %}
  {% assign page_status = raw_status %}
{% endif %}
{% case page_status %}
{% when "inbox" %}
  {% assign status_label = "roadmap.status.inbox" | t %}
  {% assign status_badge_class = "badge-neutral" %}
{% when "planned" %}
  {% assign status_label = "roadmap.status.planned" | t %}
  {% assign status_badge_class = "badge-info" %}
{% when "in_progress" %}
  {% assign status_label = "roadmap.status.in_progress" | t %}
  {% assign status_badge_class = "badge-warning" %}
{% when "completed" %}
  {% assign status_label = "roadmap.status.completed" | t %}
  {% assign status_badge_class = "badge-success" %}
{% else %}
  {% if raw_status contains "t:" or raw_status contains "roadmap.status." %}
    {% assign status_label = raw_status | replace: "t:", "" | t %}
  {% else %}
    {% assign status_label = raw_status %}
  {% endif %}
  {% assign status_badge_class = "badge-neutral" %}
{% endcase %}
<span class="badge badge-sm border-0 font-medium {{ status_badge_class }}{% if class != blank %} {{ class }}{% endif %}">{{ status_label }}</span>

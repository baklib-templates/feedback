<!-- Site footer -->
<footer class="border-t border-base-300">
    <div class="max-w-7xl px-4 mx-auto sm:px-6">
        <div class="py-8">

            <div class="flex flex-col items-center justify-center mb-4 md:flex-row md:justify-between">
                <div class="mr-4 shrink-0">
                    <a class="inline-flex mb-8 group md:mb-0 space-x-2" href="/" aria-label="{{ site.name }}">
                        {% assign logo = 'images/demo/logo.svg' | asset_url %}
                        <img src="{{ site.settings.logo_url | default: logo }}" class="w-auto h-8 hover:scale-175 hover:rotate-2" alt="{{ site.name }}" />
                    </a>
                    <p>{{ site.settings.slogan }}</p>
                </div>
                <div class="mb-2 text-sm font-medium md:order-1 md:mb-0">
                    <div class="inline-flex flex-wrap space-x-6 text-sm">
                        {{ site.settings.footer_menu_html }}
                    </div>
                </div>
            </div>

            <div class="text-center md:flex md:items-center md:justify-between">
                <div class="text-sm text-base-content/60">&copy; {{ site.name }}. {{ 'generic.copyright' | t }}. <a href="https://beian.miit.gov.cn/" target="_blank">{{ site.settings.copyright_info }}</a></div>
            </div>

        </div>
    </div>
</footer>

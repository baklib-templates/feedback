{% assign avatar_url = 'https://api.dicebear.com/7.x/rings/svg?seed=' | append: page.author.id %}
{% assign page_status = page.settings.status.value | default: page.settings.status | default: 'inbox' %}
{% assign page_board = page.settings.board.value | default: page.settings.board | default: 'feature_request' %}
{% if page_board contains 't:' %}
  {% assign board_display = page_board | replace: 't:', '' | t %}
{% else %}
{% case page_board %}
{% when 'feature_request' %}{% assign board_display = 'roadmap.board.feature_request' | t %}
{% when 'bug' %}{% assign board_display = 'roadmap.board.bug' | t %}
{% when 'task' %}{% assign board_display = 'roadmap.board.task' | t %}
{% when 'question' %}{% assign board_display = 'roadmap.board.question' | t %}
{% else %}{% assign board_display = page_board %}
{% endcase %}
{% endif %}

<article
  class="flex overflow-hidden rounded-2xl border border-base-300 bg-base-100 transition-colors hover:border-primary/30"
>
  <div class="relative flex flex-col flex-1 min-w-0 gap-2 p-4 sm:p-5 cursor-pointer sm:pr-4">
    {% if page.settings.pinned %}
      <div class="flex absolute top-3 right-3 gap-1 items-center text-xs font-semibold uppercase tracking-wide text-primary sm:right-20">
        {% render 'icon', name: 'star', class: 'w-3.5 h-3.5 fill-current' %}
        {{ 'generic.pinned' | t }}
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-2 items-center">
      {% render 'status_badge', status: page_status %}
    </div>

    <h3 class="pr-8 text-base font-semibold leading-snug text-base-content line-clamp-2">
      {{ page.settings.title }}
    </h3>

    <p class="text-sm leading-relaxed text-base-content/60 line-clamp-2">
      {{ page.settings.content | strip_html | truncate: 200 }}
    </p>

    <div class="flex flex-wrap gap-3 justify-between items-center pt-1">
      <div class="flex gap-2 items-center min-w-0">
        <img
          class="object-cover w-6 h-6 rounded-full bg-base-200"
          src="{{ page.author.avatar_url | default: avatar_url }}"
          alt=""
          width="24"
          height="24"
        >
        <p class="text-sm truncate text-base-content/80">
          <span class="font-medium text-base-content">{{ page.author.name }}</span>
          <span class="mx-1 text-base-content/40">·</span>
          <span class="text-base-content/60">{{ page.created_at | time_ago }}</span>
        </p>
      </div>

      <div class="flex flex-wrap gap-2 items-center text-xs text-base-content/60">
        <span class="inline-flex gap-1 items-center rounded-xl border border-base-300 bg-base-200/50 px-2 py-0.5">
          {% render 'page_icon', page: page, class: 'w-3.5 h-3.5 text-primary/70' %}
          {{ board_display }}
        </span>
        <span class="inline-flex gap-1 items-center">
          {% render 'icon', name: 'message-circle', class: 'w-3.5 h-3.5' %}
          {{ page.comments | size }}
        </span>
      </div>
    </div>

    <a
      class="absolute inset-0"
      href="{{ page.path }}"
      data-turbo-frame="_top"
      aria-label="{{ page.settings.title }}"
    ></a>
  </div>

  <div
    class="flex shrink-0 overflow-hidden rounded-r-2xl border-l border-base-300"
    x-data="{ posted_feedback: {{ page.visitor_posted_feedback | present? }}, feedback_count: {{ page | feedback_type_count: site.settings.feedback_useful_type }} }"
    @click.stop
  >
    <div x-show="posted_feedback" x-cloak class="flex">
      {% form_tag 'delete_feedback', page: page, useful_type: site.settings.feedback_useful_type, class: 'flex' %}
        <button
          type="submit"
          name="feedback[useful_type]"
          value="{{ site.settings.feedback_useful_type }}"
          class="flex flex-col justify-center items-center gap-0.5 px-4 py-3 w-16 sm:w-[4.5rem] min-h-full text-primary bg-primary/5 hover:bg-primary/10 transition-colors"
          @click="posted_feedback = false; feedback_count--"
        >
          {% render 'icon', name: 'thumbs-up', class: 'w-5 h-5' %}
          <span class="text-sm font-semibold tabular-nums" x-text="feedback_count"></span>
        </button>
      {% endform_tag %}
    </div>
    <div x-show="!posted_feedback" x-cloak class="flex">
      {% form_tag 'feedback', page: page, class: 'flex' %}
        <button
          type="submit"
          name="feedback[useful_type]"
          value="{{ site.settings.feedback_useful_type }}"
          class="flex flex-col justify-center items-center gap-0.5 px-4 py-3 w-16 sm:w-[4.5rem] min-h-full text-base-content/50 hover:text-primary hover:bg-base-200/80 transition-colors"
          @click="posted_feedback = true; feedback_count++"
        >
          {% render 'icon', name: 'thumbs-up', class: 'w-5 h-5' %}
          <span class="text-sm font-semibold tabular-nums" x-text="feedback_count"></span>
        </button>
      {% endform_tag %}
    </div>
  </div>
</article>

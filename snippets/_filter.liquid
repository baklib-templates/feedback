<div
  class="flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between"
  x-data="{
    status: '{{ params.status }}',
    board: '{{ params.board }}',
    sort: '{{ params.sort }}',
    q: '{{ params.q }}',
    showInput: {{ params.q | present? }},
    filterOpen: false,
    filterTab: 'status'
  }"
>
  <a :href="`?status=${status}&board=${board}&sort=${sort}&q=${encodeURIComponent(q)}`" x-ref="filterSubmit" class="hidden" aria-hidden="true"></a>

  <div class="flex flex-wrap gap-1 rounded-2xl border border-base-300 bg-base-200/60 p-1">
    <button
      type="button"
      class="btn btn-sm gap-1.5 border-0 shadow-none font-semibold"
      :class="(sort === '' || sort === '-feedbacks_count') ? 'btn-primary' : 'btn-ghost text-base-content/70'"
      @click="sort = '-feedbacks_count'; $nextTick(() => { $refs.filterSubmit.click() })"
    >
      {% render 'icon', name: 'trending-up', class: 'w-4 h-4' %}
      {{ 'home.sort_top' | t }}
    </button>
    <button
      type="button"
      class="btn btn-sm gap-1.5 border-0 shadow-none font-semibold"
      :class="sort === '-created_at' ? 'btn-primary' : 'btn-ghost text-base-content/70'"
      @click="sort = '-created_at'; $nextTick(() => { $refs.filterSubmit.click() })"
    >
      {% render 'icon', name: 'clock', class: 'w-4 h-4' %}
      {{ 'home.sort_new' | t }}
    </button>
    <button
      type="button"
      class="btn btn-sm gap-1.5 border-0 shadow-none font-semibold"
      :class="sort === '-published_at' ? 'btn-primary' : 'btn-ghost text-base-content/70'"
      @click="sort = '-published_at'; $nextTick(() => { $refs.filterSubmit.click() })"
    >
      {% render 'icon', name: 'sparkles', class: 'w-4 h-4' %}
      {{ 'home.sort_trending' | t }}
    </button>
  </div>

  <div class="flex flex-wrap gap-2 items-center lg:justify-end">
    <div class="flex relative flex-1 items-center min-w-[12rem] lg:flex-none lg:min-w-0">
      <button
        type="button"
        @click="showInput = true; $nextTick(() => $refs.searchInput.focus())"
        x-show="!showInput"
        class="btn btn-sm btn-ghost gap-2 w-full rounded-xl border border-base-300 bg-base-100 font-medium text-base-content/80 lg:w-auto"
      >
        {% render 'icon', name: 'search', class: 'w-4 h-4 text-base-content/50' %}
        {{ 'generic.search' | t }}
      </button>

      <div
        x-show="showInput"
        x-cloak
        class="flex w-full items-center gap-2 rounded-xl border border-base-300 bg-base-100 px-3 py-1.5 focus-within:border-primary"
        @click.away="if (!q) showInput = false"
      >
        {% render 'icon', name: 'search', class: 'w-4 h-4 shrink-0 text-base-content/50' %}
        <input
          type="search"
          placeholder="{{ 'placeholders.search' | t }}"
          class="flex-1 min-w-0 bg-transparent border-0 text-sm text-base-content placeholder:text-base-content/50 focus:outline-none focus:ring-0"
          x-ref="searchInput"
          x-model="q"
          @keyup.enter="$refs.filterSubmit.click()"
        />
        <button
          type="button"
          @click="q = ''; showInput = false; $nextTick(() => $refs.filterSubmit.click())"
          class="btn btn-ghost btn-xs btn-circle text-base-content/50"
          aria-label="{{ 'generic.search' | t }}"
        >
          {% render 'icon', name: 'circle-x', class: 'w-3.5 h-3.5' %}
        </button>
      </div>
    </div>

    <div class="relative">
      <button
        type="button"
        @click="filterOpen = !filterOpen"
        class="btn btn-sm btn-ghost gap-2 rounded-xl border border-base-300 bg-base-100 font-medium text-base-content/80"
        :class="(status !== '' || board !== '') ? 'border-primary text-primary' : ''"
      >
        {% render 'icon', name: 'filter', class: 'w-4 h-4' %}
        <span class="hidden sm:inline">{{ 'generic.filter' | t }}</span>
      </button>

      <div
        x-show="filterOpen"
        x-cloak
        @click.away="filterOpen = false"
        x-transition
        class="absolute right-0 top-full z-50 mt-2 w-80 max-w-[calc(100vw-2rem)] rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm"
      >
        <div class="flex flex-wrap gap-2 mb-4 text-sm font-semibold">
          <button
            type="button"
            class="rounded-xl px-2 py-1"
            :class="filterTab === 'status' ? 'bg-primary/10 text-primary' : 'text-base-content/60'"
            @click="filterTab = 'status'"
          >{{ 'generic.status' | t }}</button>
          <button
            type="button"
            class="rounded-xl px-2 py-1"
            :class="filterTab === 'board' ? 'bg-primary/10 text-primary' : 'text-base-content/60'"
            @click="filterTab = 'board'"
          >{{ 'generic.board' | t }}</button>
        </div>
        <div x-show="filterTab === 'status'" class="grid grid-cols-2 gap-2 text-sm">
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="status === '' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="status = ''; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'generic.all_statuses' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="status === 'inbox' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="status = 'inbox'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.status.inbox' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="status === 'planned' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="status = 'planned'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.status.planned' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="status === 'in_progress' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="status = 'in_progress'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.status.in_progress' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="status === 'completed' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="status = 'completed'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.status.completed' | t }}</button>
        </div>
        <div x-show="filterTab === 'board'" class="grid grid-cols-2 gap-2 text-sm">
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="board === '' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="board = ''; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'generic.all_boards' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="board === 'feature_request' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="board = 'feature_request'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.board.feature_request' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="board === 'bug' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="board = 'bug'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.board.bug' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="board === 'task' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="board = 'task'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.board.task' | t }}</button>
          <button type="button" class="rounded-xl py-1.5 text-left hover:bg-base-200" :class="board === 'question' ? 'text-primary font-semibold' : 'text-base-content/80'" @click="board = 'question'; $nextTick(() => { $refs.filterSubmit.click(); filterOpen = false })">{{ 'roadmap.board.question' | t }}</button>
        </div>
      </div>
    </div>

    {% if current_user %}
      <a
        href="/s/new"
        class="btn btn-primary btn-sm gap-2 rounded-full font-semibold shadow-none"
      >
        {% render 'icon', name: 'plus', class: 'w-4 h-4' %}
        {{ 'buttons.create_post' | t }}
      </a>
    {% else %}
      {% form_tag 'sign_in_with_baklib' %}
        <input value="true" type="hidden" name="sign_up">
        <button type="submit" class="btn btn-primary btn-sm gap-2 rounded-full font-semibold shadow-none">
          {% render 'icon', name: 'plus', class: 'w-4 h-4' %}
          {{ 'buttons.create_post' | t }}
        </button>
      {% endform_tag %}
    {% endif %}
  </div>
</div>

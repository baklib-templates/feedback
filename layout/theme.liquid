<!DOCTYPE html>
<html class="scroll-smooth bg-base-100" lang="{{ site.language }}">

<head>
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="author" content="Baklib">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% meta_tags %}

  {%- comment -%}
    Runtime color injection MUST precede css/main.css (daisyUI --color-*).
    Static tokens live in src/main.css. Brand spec: statics/brand.liquid.
  {%- endcomment -%}
  {% render 'theme_runtime_colors' %}

  {{ 'baklib/shared/editor.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
  {{ 'baklib/shared/editor.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
  {{ 'javascripts/main.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
  <!-- Tailwind -->
  {{ 'css/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
  {%# TIPS：在低代码平台开发时，请打开下一行代码注释 %}
  {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
  {{ site.settings.head_html }}
</head>

<body class="antialiased tracking-tight font-inter bg-base-100 text-base-content" id="js-body" >
  <!-- Page wrapper -->
  <div class="relative flex flex-col min-h-screen overflow-hidden supports-[overflow:clip]:overflow-clip">
    {% render "header", page: page %}
    <main class="grow">
      {{ content_for_layout }}
    </main>
    {% render "footer" %}
  </div>
  <div id="x-teleport-target" class="relative z-[60] h-0 overflow-hidden"></div>
  <div
    id="headlessui-dialog"
    role="dialog"
    aria-modal="true"
    aria-roledescription="dialog"
    class="fixed inset-0 z-[200] hidden overflow-y-auto overflow-x-hidden"
  ></div>
</body>

</html>

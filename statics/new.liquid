{% assign title = 'buttons.create_post' | t %}
{% set_meta_title title %}

{% if current_user %}
  <div class="min-h-screen bg-base-200">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:py-10">
      <nav class="mb-6">
        <a href="/" class="btn btn-ghost btn-sm gap-2 font-medium text-base-content/70 hover:text-base-content">
          {% render 'icon', name: 'arrow-left', class: 'w-4 h-4' %}
          {{ 'generic.back' | t }}
        </a>
      </nav>

      <div class="mx-auto w-full max-w-2xl">
        {% render 'section_hero', title: title, class: 'mb-6 max-w-none' %}

        <div
          class="overflow-hidden rounded-2xl border border-base-300 bg-base-100 shadow-sm"
          id="page_form"
          x-data="{ status: 'inbox', board: 'feature_request', board_name: {{ 'roadmap.board.feature_request' | t | json }}, icon: 'message-square' }"
        >
          {% form_tag 'page' %}
            {% render 'page_form', page: page, action: 'create' %}
          {% endform_tag %}
        </div>
      </div>
    </div>
  </div>
{% else %}
  <div class="mx-auto w-2/3 min-h-fit max-w-7xl px-4 sm:px-6">
    {{ 'buttons.redirect_to' | t }}
    {% form_tag 'sign_in_with_baklib' %}
      <input value="true" type="hidden" name="sign_up">
      <input
        type="submit"
        value="{{ 'buttons.login' | t }}"
        class="btn btn-primary items-center hidden px-3 py-2 text-sm font-medium lg:px-5"
        data-disable-with="..."
        x-init="$el.click()"
      >
    {% endform_tag %}
  </div>
{% endif %}
